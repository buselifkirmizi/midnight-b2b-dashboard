    "@midnight-ntwrk/midnight-js-utils": "^4.1.1",
    "@midnight-ntwrk/testkit-js": "^4.1.1",
    "@midnight-ntwrk/wallet": "^5.0.0",
    "@midnight-ntwrk/wallet-api": "^5.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.1.2",
