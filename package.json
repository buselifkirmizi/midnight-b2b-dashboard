{
  "name": "midnight-b2b-dashboard",
  "version": "1.0.0",
  "description": "This project aims to build a decentralized B2B dashboard for freelancers and agencies to manage client agreements securely. While the existence of a contract and its timestamp will be public on the ledger, sensitive details like client names, payment amounts, and project scopes will remain completely hidden using Midnight's privacy-first architecture.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "deploy": "tsx src/deploy.ts",
    "deploy-agreement": "node --experimental-specifier-resolution=node --loader ts-node/esm src/deploy.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buselifkirmizi/midnight-b2b-dashboard.git"
  },
